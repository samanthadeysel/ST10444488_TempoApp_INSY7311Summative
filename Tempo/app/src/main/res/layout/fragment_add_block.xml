<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/add_title"
        android:layout_width="372dp"
        android:layout_height="26dp"
        android:text="Create New Block"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.428"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <EditText android:id="@+id/input_title" android:hint="Title"
        app:layout_constraintTop_toBottomOf="@id/add_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="0dp" android:layout_height="wrap_content"/>

    <EditText android:id="@+id/input_time" android:hint="Time Allocation"
        app:layout_constraintTop_toBottomOf="@id/input_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="0dp" android:layout_height="wrap_content"/>

    <EditText android:id="@+id/input_date" android:hint="Date"
        app:layout_constraintTop_toBottomOf="@id/input_time"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="0dp" android:layout_height="wrap_content"/>

    <EditText android:id="@+id/input_start" android:hint="Start Time"
        app:layout_constraintTop_toBottomOf="@id/input_date"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="0dp" android:layout_height="wrap_content"/>

    <EditText android:id="@+id/input_category" android:hint="Category"
        app:layout_constraintTop_toBottomOf="@id/input_start"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="0dp" android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/input_details"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Details"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/input_category" />

    <Button
        android:id="@+id/btn_save"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Save"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/input_details" />
</androidx.constraintlayout.widget.ConstraintLayout>
