<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_blue"
    android:padding="@dimen/screen_padding">

    <TextView
        android:id="@+id/tvCurrentTimeTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvTimerTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Hon. Group"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvCurrentTimeTop"
        android:layout_marginTop="@dimen/top_spacing"/>

    <TextView
        android:id="@+id/tvTimerType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Study Time"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvTimerTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="6dp"/>

    <TextView
        android:id="@+id/tvFinishLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Finish Time: 10:00"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvTimerType"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="6dp"/>

    <FrameLayout
        android:id="@+id/timerContainer"
        android:layout_width="300dp"
        android:layout_height="300dp"
        app:layout_constraintTop_toBottomOf="@id/tvFinishLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <!-- Track: use a light track color; progress will be drawn by cpiProgress -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/cpiTrack"
            style="@style/Widget.MaterialComponents.CircularProgressIndicator"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:indicatorSize="300dp"
            app:trackThickness="18dp"
            app:indicatorInset="0dp"
            app:indicatorColor="@color/cloud_white"
            app:trackColor="@color/cloud_white"
            />

        <!-- Foreground progress (beige segment) - determinate; progress set in code -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/cpiProgress"
            style="@style/Widget.MaterialComponents.CircularProgressIndicator"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:indicatorSize="300dp"
            app:trackThickness="18dp"
            app:indicatorInset="0dp"
            app:indicatorColor="@color/light_sun"
            app:trackColor="@android:color/transparent"
            />

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:background="@drawable/inner_circle_bg"/>

        <TextView
            android:id="@+id/tvTimerRemaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25:00"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/gray_text"
            android:layout_gravity="center"/>
    </FrameLayout>

    <Button
        android:id="@+id/btnStopTimer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Stop"
        android:backgroundTint="@color/beige_bg"
        android:textColor="@color/dark_blue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
