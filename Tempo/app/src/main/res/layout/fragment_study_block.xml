<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/light_blue"
    android:padding="@dimen/container_padding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="@dimen/half_margin">

        <TextView
            android:id="@+id/tvBlockTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hon. Group"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>

    </LinearLayout>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvBlockType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Study Time"
        android:textSize="14sp"
        android:textColor="@color/white"
        android:layout_marginBottom="@dimen/standard_margin"/>

    <!-- Info card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/beige_bg"
        android:padding="@dimen/container_padding"
        android:layout_marginBottom="@dimen/standard_margin">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvStartTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start: 09:00"
                android:textColor="@color/dark_blue"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvFinishTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Finish: 10:00"
                android:textColor="@color/dark_blue"
                android:textSize="16sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Details or notes about this study block go here."
            android:textColor="@color/gray_text"
            android:textSize="14sp"
            android:layout_marginTop="@dimen/half_margin"/>
    </LinearLayout>

    <!-- Action row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="@dimen/standard_margin">

        <Button
            android:id="@+id/btnStartTimer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start"
            android:backgroundTint="@color/light_blue"
            android:textColor="@color/white"/>

        <Button
            android:id="@+id/btnEditBlock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edit"
            android:layout_marginStart="@dimen/half_margin"
            android:layout_marginEnd="@dimen/half_margin"
            android:backgroundTint="@color/dark_blue"
            android:textColor="@color/white"/>

        <Button
            android:id="@+id/btnDeleteBlock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Delete"
            android:backgroundTint="@color/beige_bg"
            android:textColor="@color/dark_blue"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnReschedule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RESCHEDULE"
        android:backgroundTint="@color/beige_bg"
        android:textColor="@color/dark_blue"
        android:layout_marginTop="@dimen/half_margin"/>
</LinearLayout>
